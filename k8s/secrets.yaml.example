# ============================================================
# SECRETS TEMPLATE
# ============================================================
# Copia este archivo como secrets.yaml y reemplaza los valores
# con los reales (base64 encoded).
#
# Para codificar: echo -n "tu-valor" | base64
#
# ⚠️ NUNCA comitees el secrets.yaml real al repositorio
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: openclaw-secrets
  namespace: openclaw
type: Opaque
data:
  DEEPSEEK_API_KEY: ""           # base64 de tu API key
  OPENAI_API_KEY: ""             # base64 de tu API key (opcional)
  OPENCLAW_GATEWAY_TOKEN: ""     # base64 del gateway token
  RUNNER_PASSWORD: ""            # base64 del password del runner
  RUNNER_USERNAME: cnVubmVyDQ==  # "runner" en base64
---
apiVersion: v1
kind: Secret
metadata:
  name: openclaw-ssh-keys
  namespace: openclaw
type: Opaque
data:
  authorized_keys: ""            # llaves públicas SSH autorizadas
  id_sandbox: ""                 # llave privada del sandbox runner
  id_sandbox.pub: ""             # llave pública del sandbox runner
  rpi3-key: ""                   # llave privada RPi3
  rpi3-key.pub: ""               # llave pública RPi3
